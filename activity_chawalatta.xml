                app:layout_constraintTop_toTopOf="parent">

                <LinearLayout
                    android:layout_marginStart="10dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Title -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🍚 Chawal Atta – A Nutritious Rice Flour"
                        android:textColor="#FFA200"
                        android:textSize="24sp"
                        android:fontFamily="sans-serif-medium"
                        android:gravity="center"
                        android:paddingBottom="12dp" />

                    <!-- Intro Text -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="✨ Chawal Atta, or rice flour, is a gluten-free alternative that provides a rich, smooth texture to your recipes. It’s widely used in Indian cuisine and perfect for those with dietary sensitivities."
                        android:textColor="#FFFFFF"
                        android:textSize="20sp"
                        android:lineSpacingExtra="6dp"
                        android:paddingBottom="12dp" />

                    <!-- Nutritional Highlights -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="📊 Nutritional Highlights (Per 100g Chawal Atta):"
                        android:textColor="#FFCC00"
                        android:textSize="21sp"
                        android:fontFamily="sans-serif-medium"
                        android:paddingBottom="8dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🔥 Calories: ~366 kcal\n⚡ Carbohydrates: ~80g (provides energy)\n🌾 Fiber: ~3g (supports digestive health)\n💪 Protein: ~6g (supports muscle growth)\n🩸 Iron: ~1.4mg (supports healthy blood circulation)"
                        android:textColor="#FFFFFF"
                        android:textSize="20sp"
                        android:lineSpacingExtra="6dp"
                        android:paddingBottom="12dp" />

                    <!-- Benefits of Eating Chawal Atta -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🌟 Benefits of Including Chawal Atta in Your Diet:"
                        android:textColor="#FFD700"
                        android:textSize="21sp"
                        android:fontFamily="sans-serif-medium"
                        android:paddingBottom="8dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🚫 Gluten-Free: Ideal for those with gluten intolerance or celiac disease.\n⚡ High in Carbohydrates: Provides a great energy boost.\n🌱 Good for Digestion: Rich in fiber that aids in digestion and keeps the gut healthy.\n⚖️ Supports Weight Management: Low in fat and can be part of a balanced diet."
                        android:textColor="#FFFFFF"
                        android:textSize="20sp"
                        android:lineSpacingExtra="6dp"
                        android:paddingBottom="12dp" />

                    <!-- Closing Text -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🥣 Chawal Atta can be used for making chapatis, snacks, sweets, and more. Embrace its versatility and enjoy its nutritional benefits!"
                        android:textColor="#FAFAFA"
                        android:textSize="20sp"
                        android:lineSpacingExtra="6dp"
                        android:paddingBottom="12dp" />
