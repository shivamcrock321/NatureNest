<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"

    tools:context=".viewmore"
    android:id="@+id/atta"
    android:background="@color/black">




        <!-- RelativeLayout with TextView and ImageButton -->

        <!-- ScrollView below RelativeLayout -->
        <RelativeLayout
            android:id="@+id/freshfruits"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_marginStart="21dp"
                android:text="Chakki Fresh Atta"
                android:textColor="#FFC107"
                android:textSize="25dp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/chatbtn"
                android:layout_width="56dp"
                android:layout_height="46dp"
                android:layout_alignParentEnd="true"
                android:layout_gravity="center"
                android:layout_marginLeft="10dp"
                android:layout_marginEnd="20dp"
                android:adjustViewBounds="true"
                android:background="@color/black"
                android:scaleType="fitXY"
                android:src="@drawable/chat" />
        </RelativeLayout>

        <LinearLayout
            android:id="@+id/search"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/freshfruits">

            <EditText
                android:id="@+id/search_bar"
                android:layout_width="0dp"
                android:layout_height="45dp"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_weight="1"
                android:background="@drawable/search_bar_background"
                android:drawableLeft="@drawable/search"
                android:drawablePadding="10dp"
                android:elevation="4dp"
                android:hint="Search"
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:paddingStart="15dp"
                android:paddingEnd="15dp"
                android:textColor="#FFC107"
                android:textColorHint="@color/white"
                android:textSize="18sp" />
        </LinearLayout>

        <ScrollView
            android:id="@+id/margintop"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/search"
            app:layout_constraintBottom_toBottomOf="parent">

            <LinearLayout
                android:id="@+id/container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="10dp">



                <FrameLayout
                    android:id="@+id/mmultigrainbtn"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp">




                    <ImageButton
                        android:id="@+id/multigrainbtn"
                        android:layout_width="match_parent"
                        android:layout_height="150dp"
                        android:layout_marginLeft="10dp"
                        android:layout_marginRight="10dp"
                        android:layout_gravity="center"
                        android:background="@drawable/multigrainbtn" />
                    <ImageView
                        android:id="@+id/multigrainbtn_not_available_image"
                        android:layout_width="370dp"
                        android:layout_height="150dp"
                        android:layout_gravity="center"
                        android:background="@drawable/notavailableimg"
                        android:visibility="gone" />
                </FrameLayout>


                <FrameLayout
                    android:id="@+id/ggahubtn"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="50dp">



                <ImageButton
                    android:id="@+id/gahubtn"
                    android:layout_width="match_parent"
                    android:layout_height="150dp"
                    android:layout_marginLeft="10dp"
                    android:layout_marginRight="10dp"
                    android:layout_gravity="center"
                    android:background="@drawable/gehuatta" />
                    <ImageView
                        android:id="@+id/gahubtn_not_available_image"
                        android:layout_width="370dp"
                        android:layout_height="150dp"
                        android:layout_gravity="center"
                        android:background="@drawable/notavailableimg"
                        android:visibility="gone" />
                </FrameLayout>


                <FrameLayout
                    android:id="@+id/mmpsehorebtn"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="50dp">



                <ImageButton
                    android:id="@+id/mpsehorebtn"
                    android:layout_width="match_parent"
                    android:layout_height="150dp"
                    android:layout_marginLeft="10dp"
                    android:layout_marginRight="10dp"
                    android:layout_gravity="center"
                    android:background="@drawable/mpsehorebtn"/>
                    <ImageView
                        android:id="@+id/mpsehorebtn_not_available_image"
                        android:layout_width="370dp"
                        android:layout_height="150dp"
                        android:layout_gravity="center"
                        android:background="@drawable/notavailableimg"
                        android:visibility="gone" />
                </FrameLayout>
                <FrameLayout
                    android:id="@+id/jjawarbtn"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="50dp">



                <ImageButton
                    android:id="@+id/jawarbtn"
                    android:layout_width="match_parent"
                    android:layout_height="150dp"
                    android:layout_marginLeft="10dp"
                    android:layout_marginRight="10dp"
                    android:layout_gravity="center"
                    android:background="@drawable/jawaratta" />
                    <ImageView
                        android:id="@+id/jawarbtn_not_available_image"
                        android:layout_width="370dp"
                        android:layout_height="150dp"
                        android:layout_gravity="center"
                        android:background="@drawable/notavailableimg"
                        android:visibility="gone" />
                </FrameLayout>

                <FrameLayout
                    android:id="@+id/cchawalbtn"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="50dp">



                <ImageButton
                    android:id="@+id/chawalbtn"
                    android:layout_width="match_parent"
                    android:layout_height="150dp"
                    android:layout_marginLeft="10dp"
                    android:layout_marginRight="10dp"
                    android:layout_gravity="center"
                    android:background="@drawable/chawalatta"
                    app:layout_constraintVertical_bias="0.631" />
                    <ImageView
                        android:id="@+id/chawalbtn_not_available_image"
                        android:layout_width="370dp"
                        android:layout_height="150dp"
                        android:layout_gravity="center"
                        android:background="@drawable/notavailableimg"
                        android:visibility="gone" />
                </FrameLayout>


                <FrameLayout
                    android:id="@+id/nnachanibtn"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="50dp">



                <ImageButton
                    android:id="@+id/nachanibtn"
                    android:layout_width="match_parent"
                    android:layout_height="150dp"
                    android:layout_marginLeft="10dp"
                    android:layout_marginRight="10dp"
                    android:layout_gravity="center"
                    android:background="@drawable/nachaniatta"
                    app:layout_constraintVertical_bias="0.631" />
                    <ImageView
                        android:id="@+id/nachanibtn_not_available_image"
                        android:layout_width="370dp"
                        android:layout_height="150dp"
                        android:layout_gravity="center"
                        android:background="@drawable/notavailableimg"
                        android:visibility="gone" />
                </FrameLayout>

                <FrameLayout
                    android:id="@+id/bbajrabtn"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="50dp">


                <ImageButton
                    android:id="@+id/bajrabtn"
                    android:layout_width="match_parent"
                    android:layout_height="150dp"
                    android:layout_marginLeft="10dp"
                    android:layout_marginRight="10dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bajraatta"
                    app:layout_constraintVertical_bias="0.932" />
                    <ImageView
                        android:id="@+id/bajrabtn_not_available_image"
                        android:layout_width="370dp"
                        android:layout_height="150dp"
                        android:layout_gravity="center"
                        android:background="@drawable/notavailableimg"
                        android:visibility="gone" />

                </FrameLayout>
            </LinearLayout>

        </ScrollView>

    </androidx.constraintlayout.widget.ConstraintLayout>